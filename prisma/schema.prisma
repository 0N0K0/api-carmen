generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Artist {
  id      Int     @id
  name    String
  link    String?
  // base URL — append ?size=small|medium|big|xl
  picture String?
  nbAlbum Int?
  nbFan   Int?

  albums Album[]
  tracks Track[]
}

model Album {
  id             Int      @id
  title          String
  upc            String?
  link           String?
  // base URL — append ?size=small|medium|big|xl
  cover          String?
  md5Image       String?
  label          String?
  nbTracks       Int?
  duration       Int?
  fans           Int?
  releaseDate    String?
  recordType     String?
  explicitLyrics Boolean?

  artistId Int
  artist   Artist @relation(fields: [artistId], references: [id])

  tracks Track[]
}

model Track {
  // --- Deezer fields ---
  // BigInt: certains ids de tracks Deezer dépassent la plage Int32 (> 2 147 483 647)
  id             BigInt   @id
  title          String
  titleShort     String?
  titleVersion   String?
  isrc           String?
  link           String?
  duration       Int
  trackPosition  Int?
  diskNumber     Int?
  rank           Int?
  releaseDate    String?
  explicitLyrics Boolean?
  preview        String?
  // Deezer bpm/gain (from track object)
  bpm            Float?
  gain           Float?

  artistId Int
  artist   Artist @relation(fields: [artistId], references: [id])

  albumId Int
  album   Album  @relation(fields: [albumId], references: [id])

  // --- freqblog audio features ---
  fbBpm                        Float?
  fbBpmAlt                     Float?
  fbBpmConfidence              Float?
  fbKey                        String?
  fbKeyConfidence              Float?
  fbKeyInt                     Int?
  fbMode                       Int?
  fbCamelot                    String?
  fbOpenKey                    String?
  fbEnergy                     Float?
  fbLoudnessDb                 Float?
  fbDanceability               Float?
  fbValence                    Float?
  fbSpeechiness                Float?
  fbInstrumentalness           Float?
  fbLiveness                   Float?
  fbAcousticness               Float?
  fbTimeSignature              Int?
  fbMood                       String?
  // { happy, sad, aggressive, relaxed, party }
  fbMoodVector                 Json?
  fbGenre                      String?
  // { gender, timbre, tonal_atonal }
  fbExtended                   Json?
  fbFeatureSource              String?
  fbRepresentativeSegmentStart Float?
  fbOnsetRate                  Float?
  fbDynamicComplexity          Float?
  fbTuningFrequency            Float?
  fbAverageLoudness            Float?

  playlists      PlaylistTrack[]
  historyEntries HistoryEntry[]
}

model Playlist {
  // BigInt: certains ids de playlists Deezer dépassent la plage Int32 (> 2 147 483 647)
  id            BigInt   @id
  title         String
  description   String?
  duration      Int?
  public        Boolean?
  isLovedTrack  Boolean?
  collaborative Boolean?
  fans          Int?
  link          String?
  // base URL — append ?size=small|medium|big|xl
  picture       String?
  checksum      String?

  folderId Int?
  folder   Folder? @relation(fields: [folderId], references: [id])

  tracks PlaylistTrack[]
}

model PlaylistTrack {
  playlistId BigInt
  playlist   Playlist @relation(fields: [playlistId], references: [id])

  trackId  BigInt
  track    Track @relation(fields: [trackId], references: [id])

  position Int
  timeAdd  Int?

  @@id([playlistId, trackId])
}

model Folder {
  id   Int    @id @default(autoincrement())
  name String

  playlists Playlist[]
}

model HistoryEntry {
  id       Int      @id @default(autoincrement())
  playedAt DateTime @default(now())

  trackId BigInt
  track   Track @relation(fields: [trackId], references: [id])
}
