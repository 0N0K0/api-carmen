generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Artist {
  id      Int     @id
  // COLLATE case_insensitive (migration 20260711065718) — pas modélisé par Prisma,
  // ne pas recréer cette colonne (db push/migrate) sans réappliquer la collation.
  name          String
  share         String?
  picture       String?
  pictureSmall  String?
  pictureMedium String?
  pictureBig    String?
  pictureXl     String?
  // favori Deezer de l'utilisateur (Pipe API)
  isFavorite Boolean?
  // épinglage local Carmen — indépendant de Deezer
  isPinned   Boolean  @default(false)
  // rang dans l'ordre manuel unifié des pins (tous types confondus) — null si pas épinglé
  pinnedOrder Int?

  albums              Album[]
  tracks              Track[]
  albumContributions  AlbumContributor[]
  trackContributions  TrackContributor[]
  folders             ArtistFolder[]
}

model Album {
  id          Int      @id
  // COLLATE case_insensitive (migration 20260711065718) — pas modélisé par Prisma,
  // ne pas recréer cette colonne (db push/migrate) sans réappliquer la collation.
  title       String
  upc         String?
  share       String?
  cover       String?
  coverSmall  String?
  coverMedium String?
  coverBig    String?
  coverXl     String?
  releaseDate String?
  recordType  String?
  available   Boolean?
  // favori Deezer de l'utilisateur (Pipe API)
  isFavorite  Boolean?
  // épinglage local Carmen — indépendant de Deezer
  isPinned    Boolean  @default(false)
  // rang dans l'ordre manuel unifié des pins (tous types confondus) — null si pas épinglé
  pinnedOrder Int?

  artistId Int
  artist   Artist @relation(fields: [artistId], references: [id])

  tracks       Track[]
  genres       AlbumGenre[]
  contributors AlbumContributor[]
  folders      AlbumFolder[]
}

model Genre {
  id      Int     @id
  name    String
  picture String?

  albums AlbumGenre[]
}

model AlbumGenre {
  albumId Int
  album   Album @relation(fields: [albumId], references: [id], onDelete: Cascade)
  genreId Int
  genre   Genre @relation(fields: [genreId], references: [id])

  @@id([albumId, genreId])
}

model AlbumContributor {
  albumId  Int
  album    Album  @relation(fields: [albumId], references: [id], onDelete: Cascade)
  artistId Int
  artist   Artist @relation(fields: [artistId], references: [id])
  // "Main", "Featured", etc. (tel que renvoyé par Deezer)
  role     String?

  @@id([albumId, artistId])
}

model Track {
  // --- Deezer fields ---
  // BigInt: certains ids de tracks Deezer dépassent la plage Int32 (> 2 147 483 647)
  id             BigInt   @id
  title          String
  titleShort     String?
  titleVersion   String?
  isrc           String?
  readable       Boolean?
  share          String?
  duration       Int
  trackPosition  Int?
  diskNumber     Int?
  rank           Int?
  explicitLyrics Boolean?
  gain           Float?
  // favori Deezer de l'utilisateur (Pipe API) — indépendant de la présence dans une playlist
  isFavorite     Boolean?

  artistId Int
  artist   Artist @relation(fields: [artistId], references: [id])

  albumId Int
  album   Album  @relation(fields: [albumId], references: [id])

  contributors TrackContributor[]

  // --- freqblog audio features ---
  fbBpm                        Float?
  fbBpmAlt                     Float?
  fbBpmConfidence              Float?
  fbKey                        String?
  fbKeyConfidence              Float?
  fbKeyInt                     Int?
  fbMode                       Int?
  fbCamelot                    String?
  fbOpenKey                    String?
  fbEnergy                     Float?
  fbLoudnessDb                 Float?
  fbDanceability               Float?
  fbValence                    Float?
  fbSpeechiness                Float?
  fbInstrumentalness           Float?
  fbLiveness                   Float?
  fbAcousticness               Float?
  fbTimeSignature              Int?
  fbMood                       String?
  // { happy, sad, aggressive, relaxed, party }
  fbMoodVector                 Json?
  fbGenre                      String?
  // { gender, timbre, tonal_atonal }
  fbExtended                   Json?
  fbOnsetRate                  Float?
  fbDynamicComplexity          Float?
  fbTuningFrequency            Float?
  fbAverageLoudness            Float?
  fbIsRemix                    Boolean?
  fbMixName                    String?
  fbRemixer                    String?
  fbRemixOfIsrc                String?

  playlists      PlaylistTrack[]
  historyEntries HistoryEntry[]
}

model TrackContributor {
  trackId  BigInt
  track    Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)
  artistId Int
  artist   Artist @relation(fields: [artistId], references: [id])
  // "Main", "Featured", etc. (tel que renvoyé par Deezer)
  role     String?

  @@id([trackId, artistId])
}

model Playlist {
  // BigInt: certains ids de playlists Deezer dépassent la plage Int32 (> 2 147 483 647)
  id            BigInt   @id
  // COLLATE case_insensitive (migration 20260711065718) — pas modélisé par Prisma,
  // ne pas recréer cette colonne (db push/migrate) sans réappliquer la collation.
  title         String
  description   String?
  public        Boolean?
  isLovedTrack  Boolean?
  collaborative Boolean?
  share         String?
  // base URL — append ?size=small|medium|big|xl
  picture       String?
  // créateur Deezer de la playlist (pas de modèle User dédié — pas d'autre usage à ce jour)
  creatorId     BigInt?
  creatorName   String?
  // permet de sauter la resynchro des tracks quand le contenu n'a pas changé côté Deezer
  // (cf. syncPlaylist, param `force` pour l'ignorer et forcer une resynchro complète)
  checksum      String?
  // épinglage local Carmen — indépendant de Deezer
  isPinned      Boolean  @default(false)
  // rang dans l'ordre manuel unifié des pins (tous types confondus) — null si pas épinglé
  pinnedOrder   Int?

  folders PlaylistFolder[]
  tracks  PlaylistTrack[]
}

model PlaylistTrack {
  playlistId BigInt
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  trackId  BigInt
  track    Track @relation(fields: [trackId], references: [id])

  position Int
  timeAdd  Int?

  @@id([playlistId, trackId])
}

model Folder {
  id   Int    @id @default(autoincrement())
  name String

  artists   ArtistFolder[]
  albums    AlbumFolder[]
  playlists PlaylistFolder[]
}

model ArtistFolder {
  artistId Int
  artist   Artist @relation(fields: [artistId], references: [id])
  folderId Int
  folder   Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@id([artistId, folderId])
}

model AlbumFolder {
  albumId  Int
  album    Album  @relation(fields: [albumId], references: [id], onDelete: Cascade)
  folderId Int
  folder   Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@id([albumId, folderId])
}

model PlaylistFolder {
  playlistId BigInt
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  folderId   Int
  folder     Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@id([playlistId, folderId])
}

model HistoryEntry {
  id       Int      @id @default(autoincrement())
  playedAt DateTime @default(now())

  trackId BigInt
  track   Track @relation(fields: [trackId], references: [id])
}
